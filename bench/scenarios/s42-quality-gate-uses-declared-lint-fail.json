{
  "name": "s42-quality-gate-uses-declared-lint-fail",
  "hook": ".claude/hooks/quality-gate.sh",
  "setup_files": {
    ".claude/commands.json": "{\"lint\": \"false\"}",
    "src/x.py": "x = 1\n"
  },
  "payload": {
    "tool_name": "Edit",
    "tool_input": { "file_path": "{TMPROOT}/src/x.py" }
  },
  "expect": {
    "exit_code": 0,
    "state": [
      { "file": ".hook-state/last_quality_gate.json", "field": "status", "equals": "failed" }
    ]
  },
  "notes": "commands.json declares lint=false → quality-gate runs the declared command (not the py guess) and records failed."
}
